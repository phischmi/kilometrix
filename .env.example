# Kopiere diese Datei nach `.env` und passe die Werte an.
# Alle Pfade relativ zum Projektwurzelverzeichnis oder absolut.

# --- OSRM-Graph ---
# Pfad zum vorgebauten Graph (Basis-Pfad ohne .osrm-Suffixe),
# z. B. data/germany.osrm  ->  erwartet data/germany.osrm.* daneben.
# Der Graph wird SEPARAT mit scripts/build_graph.sh gebaut (Default: LKW-Profil truck.lua).
OSRM_GRAPH_PATH=data/germany.osrm

# Algorithmus, mit dem der Graph gebaut wurde (muss zum build_graph-Lauf passen).
OSRM_ALGORITHM=MLD

# --- osrm-routed ---
OSRM_ROUTED_BIN=osrm-routed
OSRM_ROUTED_HOST=127.0.0.1
# Port 5000 ist auf macOS vom AirPlay-Receiver belegt -> 5001.
OSRM_ROUTED_PORT=5001
# true = Backend startet/stoppt osrm-routed selbst; false = bereits laufenden nutzen.
MANAGE_OSRM_ROUTED=true
# Optionaler Override der Basis-URL (sonst host:port).
# OSRM_ROUTED_URL=http://127.0.0.1:5001
# Log-Stufe von osrm-routed. WARNING unterdrückt die Request-Logs (die Koordinaten
# enthalten). Für Debugging auf INFO setzen.
OSRM_ROUTED_VERBOSITY=WARNING
# mmap: Graphdaten von der Platte mappen statt komplett ins RAM zu laden. Senkt den
# Leerlauf-Speicher von osrm-routed deutlich (gut für RAM-knappe NAS); die erste
# Abfrage ist minimal langsamer (auf SSD vernachlässigbar).
# Default: false auf Windows (mmap ist dort beim Laden eines großen Graphen deutlich
# langsamer), true auf Linux/macOS (wichtig für RAM-knappe NAS).
# Hinweis: Gilt nur, wenn das Backend osrm-routed selbst startet (MANAGE_OSRM_ROUTED=true).
# Läuft osrm-routed separat (z. B. Docker), dort '--mmap' im Startbefehl ergänzen.
# OSRM_ROUTED_MMAP=false

# Wie lange (Sekunden) auf den Start von osrm-routed gewartet wird. Default: 300 (5 Minuten).
# Auf langsamen Windows-Rechnern oder großen Graphen ggf. erhöhen (z. B. 600).
# OSRM_ROUTED_READY_TIMEOUT=300

# --- Geocoding (LKZ/PLZ -> Zentroid) ---
# Kompakte CSV (country,plz,lat,lon), separat via scripts/build_geocode.sh erzeugt.
# Fehlt die Datei, ist nur der Modus "Nur Routing" nutzbar (Geocoding deaktiviert).
GEOCODE_PATH=data/plz_centroids.csv

# --- Verarbeitung ---
# Parallele Worker-Threads pro /route-batch-Aufruf (8 = gemessener Sweet Spot).
WORKERS=8
# Snap-Plausi: liegt der nächste routbare Punkt weiter als dieser Wert (Meter) von der
# Eingabekoordinate entfernt, wird die Zeile als "snapped_far" markiert.
SNAP_LIMIT_M=100
# Obergrenze an Paaren pro /route-batch-Request (das Add-in chunkt automatisch darunter).
MAX_SYNC_BATCH=20000

# --- Office.js-Add-in (HTTPS, 'kilometrix serve') ---
ADDIN_HOST=127.0.0.1
ADDIN_PORT=8443

# --- Auth (nur für zentralen Betrieb, z. B. Docker hinter Traefik) ---
# Lokal aus lassen. Bei zentralem Server auf true setzen und ein Secret vergeben
# (z. B.  openssl rand -hex 32 ). Tokens: kilometrix token create --name X --days 90
AUTH_ENABLED=false
AUTH_SECRET=

# --- HTTP-Proxy (optional, z. B. Firmen-Proxy) ---
# Wird von Go's net/http automatisch genutzt (build-geocode, build-graph).
# Format: http://user:passwort@proxy.firma.de:8080  oder  http://proxy.firma.de:3128
# HTTPS_PROXY=http://proxy.firma.de:3128
# HTTP_PROXY=http://proxy.firma.de:3128
# Hosts, die den Proxy umgehen sollen (kommagetrennt, * als Wildcard):
# NO_PROXY=localhost,127.0.0.1

# --- Docker/Compose (nur für die ${...}-Substitution in docker-compose*.yml) ---
# Deine Domain (Traefik-Host-Regel). Steht NICHT im Repo — hier setzen.
KILOMETRIX_HOST=kilometrix.example.com
# App-Image aus GHCR (Prod-Compose):
KILOMETRIX_IMAGE=ghcr.io/phischmi/kilometrix:latest
# OSRM-Docker-Image (muss zur osrm-backend-Version des Graphen passen):
OSRM_IMAGE=ghcr.io/project-osrm/osrm-backend:v26.6.5-debian
