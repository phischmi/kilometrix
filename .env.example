# Kopiere diese Datei nach `.env` und passe die Werte an.
# Alle Pfade relativ zum Projektwurzelverzeichnis oder absolut.

# --- Routing-Engine ---
# "http"     = osrm-routed als lokaler Subprozess, Abfrage via HTTP (Default, empfohlen).
# "bindings" = in-process osrm-bindings (nur mit versionsgleichem Source-Build nutzbar).
ENGINE=http

# Pfad zum vorgebauten OSRM-Graph (Basis-Pfad ohne .osrm-Suffix-Erweiterungen),
# z. B. data/germany.osrm  ->  erwartet data/germany.osrm.* daneben.
# Der Graph wird SEPARAT mit scripts/build_graph.sh gebaut und nach data/ kopiert.
OSRM_GRAPH_PATH=data/germany.osrm

# Algorithmus, mit dem der Graph gebaut wurde. MLD = osrm-partition + osrm-customize.
# Muss zum build_graph-Lauf passen (CH oder MLD).
OSRM_ALGORITHM=MLD

# --- osrm-routed (nur bei ENGINE=http) ---
OSRM_ROUTED_BIN=osrm-routed
OSRM_ROUTED_HOST=127.0.0.1
# Port 5000 ist auf macOS vom AirPlay-Receiver belegt -> 5001.
OSRM_ROUTED_PORT=5001
# true = Backend startet/stoppt osrm-routed selbst; false = bereits laufenden nutzen.
MANAGE_OSRM_ROUTED=true
# Optionaler Override der Basis-URL (sonst host:port). Z. B. bei externem osrm-routed.
# OSRM_ROUTED_URL=http://127.0.0.1:5001

# --- Verarbeitung ---
# Anzahl paralleler Worker-Threads für die Routenabfragen.
WORKERS=8

# Snap-Plausi: liegt der nächste routbare Punkt weiter als dieser Wert (Meter)
# von der Eingabekoordinate entfernt, wird die Zeile als "snapped_far" markiert.
SNAP_LIMIT_M=50

# Verzeichnis für Checkpoint-/Ergebnis-Dateien.
DATA_DIR=data
CHECKPOINT_DIR=data/checkpoints

# Alle N verarbeiteten Zeilen einen Checkpoint schreiben. Höher = weniger Overhead bei
# großen Jobs (gemessen: 100k mit 200 -> ~20s, mit 2000 -> ~7s), im Crash-Fall müssen
# dafür bis zu N Zeilen neu gerechnet werden (dank Resume günstig).
CHECKPOINT_EVERY=2000

# --- Backend / Frontend ---
API_HOST=127.0.0.1
API_PORT=8000
# URL, unter der das Streamlit-Frontend das FastAPI-Backend erreicht.
BACKEND_URL=http://127.0.0.1:8000
