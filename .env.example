# Kopiere diese Datei nach `.env` und passe die Werte an.
# Alle Pfade relativ zum Projektwurzelverzeichnis oder absolut.

# --- OSRM-Graph ---
# Pfad zum vorgebauten Graph (Basis-Pfad ohne .osrm-Suffixe),
# z. B. data/germany.osrm  ->  erwartet data/germany.osrm.* daneben.
# Der Graph wird SEPARAT mit scripts/build_graph.sh gebaut (Default: LKW-Profil truck.lua).
OSRM_GRAPH_PATH=data/germany.osrm

# Algorithmus, mit dem der Graph gebaut wurde (muss zum build_graph-Lauf passen).
OSRM_ALGORITHM=MLD

# --- osrm-routed ---
OSRM_ROUTED_BIN=osrm-routed
OSRM_ROUTED_HOST=127.0.0.1
# Port 5000 ist auf macOS vom AirPlay-Receiver belegt -> 5001.
OSRM_ROUTED_PORT=5001
# true = Backend startet/stoppt osrm-routed selbst; false = bereits laufenden nutzen.
MANAGE_OSRM_ROUTED=true
# Optionaler Override der Basis-URL (sonst host:port).
# OSRM_ROUTED_URL=http://127.0.0.1:5001

# --- Verarbeitung ---
# Parallele Worker-Threads pro /route-batch-Aufruf (8 = gemessener Sweet Spot).
WORKERS=8
# Snap-Plausi: liegt der nächste routbare Punkt weiter als dieser Wert (Meter) von der
# Eingabekoordinate entfernt, wird die Zeile als "snapped_far" markiert.
SNAP_LIMIT_M=50
# Obergrenze an Paaren pro /route-batch-Request (das Add-in chunkt automatisch darunter).
MAX_SYNC_BATCH=20000

# --- Office.js-Add-in (HTTPS, scripts/serve_addin.sh) ---
ADDIN_HOST=127.0.0.1
ADDIN_PORT=8443

# --- Auth (nur für zentralen Betrieb, z. B. Docker hinter Traefik) ---
# Lokal aus lassen. Bei zentralem Server auf true setzen und ein Secret vergeben
# (z. B.  openssl rand -hex 32 ). Tokens: python -m backend.tokens create --name X --days 90
AUTH_ENABLED=false
AUTH_SECRET=
# OSRM-Docker-Image (muss zur osrm-backend-Version des Graphen passen):
OSRM_IMAGE=ghcr.io/project-osrm/osrm-backend:v26.6.5-debian
